# Visual Studio 2015/2017 user specific files
.vs/

# Visual Studio Code files
.vscode/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.code-workspace

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Library distribution build outputs.
BuildOutput/

# Cache files for the editor to use
DerivedDataCache/
Intermediate/
Saved/

# Compiled source files for the engine to use
Binaries/
Plugins/*/Binaries/
Plugins/*/Intermediate/

# Builds
Build/

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

# Backup files generated by Unreal Engine when modifying assets
Backup/

# Configuration files generated by the Editor
Saved/

# Compiled source files for the engine to use
Source/**/Binaries
Source/**/Intermediate

# Misc generated files
*.log
*.tmp
shadertoolsconfig.json
UpgradeLog.htm

# OS specific files
Thumbs.db
.DS_Store
